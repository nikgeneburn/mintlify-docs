{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "prim32",
  "description": "A 32-bytes-per-primitive immediate-mode GUI and 2D drawing library for Direct3D 12.",
  "colors": {
    "primary": "#16A34A",
    "light": "#4ADE80",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart", "integration"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/layers-and-caching",
              "concepts/performance"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Core",
            "pages": [
              "api/drawlist",
              "api/images-and-fonts",
              "api/widgets-and-windows"
            ]
          },
          {
            "group": "Modules",
            "pages": ["api/backend-d3d12", "api/profiler"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/nikgeneburn/Prim32",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/nikgeneburn/Prim32"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/nikgeneburn/Prim32"
    }
  }
}
